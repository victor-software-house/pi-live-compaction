{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error",
				"noImplicitAnyLet": "error",
				"noConfusingVoidType": "error"
			},
			"style": {
				"useImportType": "error",
				"useNodejsImportProtocol": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["../*", "../**/*"],
								"message": "Use @live-compaction/* path alias instead of relative parent imports."
							}
						]
					}
				},
				"useConsistentBuiltinInstantiation": {
					"level": "error",
					"fix": "safe"
				},
				"useExplicitLengthCheck": {
					"level": "error",
					"fix": "safe"
				},
				"useConsistentArrayType": {
					"level": "error",
					"options": { "syntax": "shorthand" }
				},
				"useThrowOnlyError": "error",
				"noEnum": "error"
			},
			"correctness": {
				"noUnusedImports": {
					"level": "error",
					"fix": "safe"
				},
				"noUnusedVariables": {
					"level": "warn",
					"fix": "none"
				},
				"noUnusedFunctionParameters": {
					"level": "error",
					"fix": "safe"
				},
				"noUndeclaredVariables": "error"
			},
			"performance": {
				"noDelete": "error",
				"noDynamicNamespaceImportAccess": "error"
			},
			"complexity": {
				"noForEach": "error",
				"noUselessTypeConstraint": "error"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always"
		}
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"overrides": [
		{
			"includes": ["test/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "warn"
					},
					"style": {
						"noNonNullAssertion": "warn"
					}
				}
			}
		}
	]
}
