{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@live-compaction/*": ["./extensions/live-compaction/*"],
			"@test/*": ["./test/*"]
		}
	},
	"include": ["extensions/**/*.ts", "test/**/*.ts", "bin/**/*.ts", "vitest.config.ts"],
	"exclude": ["node_modules"]
}
